    // ─── Auth Actions ─────────────────────────────────────────────────────────

    public function forgot_password() {
        try {
            if (!isset($_POST['email']) || empty(trim($_POST['email']))) {
                throw new Exception('Email is required');
            }

            $email = trim($_POST['email']);
            $result = $this->coreModel->forgot_password($email);
            echo json_encode($result);
        } catch (Exception $e) {
            echo json_encode(['status' => false, 'message' => $e->getMessage()]);
        }
    }

    public function change_password() {
        try {
            $requiredFields = ['current_password', 'new_password', 'confirm_password'];
            foreach ($requiredFields as $field) {
                if (!isset($_POST[$field]) || empty(trim($_POST[$field]))) {
                    throw new Exception("Missing required field: $field");
                }
            }

            $current_password = $_POST['current_password'];
            $new_password = $_POST['new_password'];
            $confirm_password = $_POST['confirm_password'];

            if ($new_password !== $confirm_password) {
                throw new Exception('New passwords do not match');
            }

            $result = $this->coreModel->change_password($current_password, $new_password);

            if ($result['status']) {
                $this->coreModel->logActivity('password_changed', 'Password Changed', 'User password was changed', 'auth');
            }

            echo json_encode($result);
        } catch (Exception $e) {
            echo json_encode(['status' => false, 'message' => $e->getMessage()]);
        }
    }


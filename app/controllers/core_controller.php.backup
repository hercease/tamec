    public function generate_payroll() {
        try {
            $requiredFields = ['staff_id', 'start_date', 'end_date', 'hourly_rate'];
            foreach ($requiredFields as $field) {
                if (!isset($_POST[$field]) || $_POST[$field] === '') {
                    throw new Exception("Missing required field: $field");
                }
            }

            $data = [
                'staff_id' => (int)$_POST['staff_id'],
                'start_date' => $_POST['start_date'],
                'end_date' => $_POST['end_date'],
                'hourly_rate' => (float)$_POST['hourly_rate'],
                'notes' => $_POST['notes'] ?? ''
            ];

            $result = $this->coreModel->generate_payroll($data);

            if ($result['status']) {
                $this->coreModel->logActivity('payroll_generated', 'Payroll Generated', 'Payroll was generated for staff ID ' . $data['staff_id'], 'payroll');
            }

            echo json_encode($result);
        } catch (Exception $e) {
            echo json_encode(['status' => false, 'message' => $e->getMessage()]);
        }
    }


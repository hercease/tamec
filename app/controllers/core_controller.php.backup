                $this->coreModel->logActivity('client_' . $action, 'Client ' . ucfirst($action), 'Client ' . $clientData['client_name'] . ' was ' . $action, 'client');
                echo json_encode($response);
            } else {
                echo json_encode($response);
            }
        } catch (Exception $e) {
            echo json_encode(['status' => false, 'message' => $e->getMessage()]);
        }
    }


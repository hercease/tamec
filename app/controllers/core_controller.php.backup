    public function save_user_document() {
        try {
            if (!isset($_POST['staff_id']) || !isset($_POST['doc_id'])) {
                throw new Exception('Staff ID and Document ID are required');
            }

            $staff_id = (int)$_POST['staff_id'];
            $doc_id = (int)$_POST['doc_id'];
            $doc_tag = trim($_POST['doc_tag'] ?? '');
            $file_path = trim($_POST['file_path'] ?? '');
            $original_name = trim($_POST['original_name'] ?? '');

            $result = $this->coreModel->save_user_document($staff_id, $doc_id, $doc_tag, $file_path, $original_name);

            if ($result['status']) {
                $this->coreModel->logActivity('document_uploaded', 'Document Uploaded', 'Document was uploaded for staff ID ' . $staff_id, 'document');
            }

            echo json_encode($result);
        } catch (Exception $e) {

    public function saveSchedule() {
        try {
            $data = $_POST;
            $validation = $this->validateScheduleRequest($data);

            if (!$validation['valid']) {
                echo json_encode(['status' => false, 'message' => implode(', ', $validation['errors'])]);
                return;
            }

            $result = $this->coreModel->saveSchedule($data);

            if ($result['status']) {
                $this->coreModel->logActivity('schedule_created', 'Schedule Created', 'New schedule was created for client ID ' . $data['client_id'], 'schedule');
            }

            echo json_encode($result);
        } catch (Exception $e) {
            echo json_encode(['status' => false, 'message' => 'Error saving schedule: ' . $e->getMessage()]);
        }
    }

    private function validateScheduleRequest($data) {
        $errors = [];
        if (empty($data['client_id'])) $errors[] = 'Client ID is required';
        if (empty($data['schedules']) || !is_array($data['schedules'])) {
            $errors[] = 'No schedules to save';
        } else {
            foreach ($data['schedules'] as $schedule) {
                if (empty($schedule['staff_id'])) $errors[] = 'Staff ID is required for all schedules';
                if (empty($schedule['date'])) $errors[] = 'Date is required for all schedules';
                if (empty($schedule['start_time'])) $errors[] = 'Start time is required for all schedules';
                if (empty($schedule['end_time'])) $errors[] = 'End time is required for all schedules';
            }
        }
        return ['valid' => empty($errors), 'errors' => $errors];
    }

